ANTHROPIC_API_KEY=your-api-key-here

# Optional: agent model override. Default is claude-haiku-4-5 (fast, cheap).
# Use claude-sonnet-5 for stronger reasoning + artifact generation.
# AGENT_MODEL=claude-sonnet-5

# Optional: natural-sounding voice replies via ElevenLabs (free tier works).
# Without a key, voice mode falls back to the browser's built-in speech.
# ELEVENLABS_API_KEY=your-elevenlabs-key
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
